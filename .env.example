# SMTP Configuration for Email Sending
# Configure these values to enable the contact form email functionality

# SMTP Server Host (e.g., smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=smtp.gmail.com

# SMTP Server Port (typically 587 for TLS or 465 for SSL)
SMTP_PORT=587

# Use secure connection (true for port 465, false for 587)
SMTP_SECURE=false

# SMTP Username/Email
SMTP_USER=your-email@gmail.com

# SMTP Password (for Gmail, use App Password if 2FA is enabled)
SMTP_PASSWORD=your-app-password

# From email address for outgoing emails
SMTP_FROM=your-email@gmail.com

# Destination email address for contact form submissions
CONTACT_EMAIL=rouel.sato94@gmail.com

# Example Gmail Setup:
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Set SMTP_USER=your-email@gmail.com
# 4. Set SMTP_PASSWORD to the generated 16-character password
# 5. Set SMTP_HOST=smtp.gmail.com
# 6. Set SMTP_PORT=587
# 7. Set SMTP_SECURE=false
